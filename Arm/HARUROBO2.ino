void setTarget(int x, int y, int r1, int r2){
  /*
  target[0]+=2*(x1-x2);
  target[1]+=2*(y2-y1);
  */
  if(x<-20){target[0]-=1;}
  if(x> 20){target[0]+=1;}
  if(y<-20){target[1]-=1;}
  if(y> 20){target[1]+=1;}
  target[2]=clip2pi(0.01*PI*(r1-r2)+target[2]);
  wrist[0]=(lengths[2]*cos(target[2]))+target[0];//
  wrist[1]=(lengths[2]*sin(target[2]))+target[1];//

}

void getAngle(){
  dist2=sq(wrist[0])+sq(wrist[1]);
  dist=sqrt(dist2);
  angles[0]=clip2pi(acos(constrain(
      (dist2+sqlen[0]-sqlen[1])/(2*dist*lengths[0]),-1.0f,1.0f)) + atan2(wrist[1],wrist[0]));//
  angles[1]=clip2pi(acos(constrain(
      (sqlen[0]+sqlen[1]-dist2)/(2*lengths[0]*lengths[1]),-1.0f,1.0f)));//
  angles[2]=clip2pi(target[2]-angles[0]-angles[1]+(PI/2));
}
